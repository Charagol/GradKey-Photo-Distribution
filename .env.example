# ==========================================================================
# 毕业季专属相册 — 环境配置文件
# ==========================================================================
# 使用方法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填写下方必填项 (OSS 配置)
#   3. 启动应用:             uvicorn app.main:app --host 0.0.0.0 --port 8000
# ==========================================================================

# --- 阿里云 OSS 配置 (必填) ---
# 用于存储上传的照片，实现动静分离。
# 请先在阿里云 OSS 控制台创建 Bucket，并生成 AccessKey。
# ⚠️ 重要: 创建 Bucket 后务必配置 CORS（跨域规则），见 README.md 中的 OSS 配置指南。
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY=your_access_key_here
OSS_SECRET=your_secret_here
OSS_BUCKET=your_bucket_name

# --- OSS 签名 URL 有效期（秒）---
# 签名 URL 用于安全访问 OSS 中的照片，过期后自动失效。
# 默认 900 秒（15 分钟），可适当调整。
OSS_SIGNED_URL_EXPIRES=900

# --- 数据库配置 ---
# SQLite 本地文件数据库，无需额外安装。
# 默认文件路径为项目根目录下的 album.db。
DATABASE_URL=sqlite:///album.db

# --- JWT 配置 ---
# JWT 密钥用于签发管理员和学生令牌。
# ⚠️ 生产环境务必替换为随机长字符串！
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
